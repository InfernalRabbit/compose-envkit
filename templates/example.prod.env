# ============================================
# Production overlay (non-secret).  cp example.prod.env .prod.env on the server.
# Loaded as the .${COMPOSE_ENV}.env layer when COMPOSE_ENV=prod (i.e. between
# .env and .secrets.env). Real prod secrets still go in .secrets.env.
# ============================================

NODE_ENV=production

# --- Deterministic compose file selection (override the root .env) ----------
# Re-pin COMPOSE_FILE here so prod is self-contained: any `${FLAG:+…}` overlay
# you want ON in prod must be spelled out explicitly, because the root .env's
# `${FLAG:+…}` was already expanded at .env-parse time (when FLAG was still
# empty). Without this, an overlay you only intend for prod would be dropped.
# Example pinning a TLS/ingress overlay for prod:
#   COMPOSE_FILE=docker-compose.yml:docker-compose.tls.yml:docker-compose.prod.yml
COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml

# --- Public-facing config ---------------------------------------------------
# Lock down to the real deployed origin(s). Adjust to match your SITE_URL.
APP_PUBLIC_URL=https://app.example.com
ACME_EMAIL=admin@example.com
