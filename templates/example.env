# ============================================
# Root env (non-secret).  cp example.env .env  → fill in.
# Secrets go in .secrets.env (see example.secrets.env). NEVER put
# passwords / keys / tokens here — this file is template-tracked (committed).
# ============================================

# Compose identity + which environment overlay to load.
COMPOSE_PROJECT_NAME=myproject
COMPOSE_ENV=dev

# --- Compose file selection ------------------------------------------------
# Pick overlays by environment. The base file is always present; the
# per-environment overlay is chosen by ${COMPOSE_ENV}. Add your own optional
# overlays with the `${FLAG:+:file}` idiom (expands to ":file" only when FLAG
# is set non-empty), e.g. a TLS/ingress overlay toggled by a custom flag:
#   OVERLAY_TLS=
#   COMPOSE_FILE=docker-compose.yml${OVERLAY_TLS:+:docker-compose.tls.yml}:docker-compose.${COMPOSE_ENV}.yml
# Note: ${FLAG:+…} is expanded at .env-parse time, so a flag you only set in a
# later overlay (e.g. .prod.env) must ALSO be pinned in that overlay's
# COMPOSE_FILE — see example.prod.env for the deterministic pattern.
COMPOSE_FILE=docker-compose.yml:docker-compose.${COMPOSE_ENV}.yml

# --- Application (non-secret) ----------------------------------------------
SITE_URL=example.com
APP_PORT=8080
APP_PUBLIC_URL=https://app.example.com

# --- Database (non-secret; password lives in .secrets.env) -----------------
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=appdb
DATABASE_USER=appuser

# --- Redis (non-secret; REDIS_PASSWORD lives in .secrets.env) --------------
# Keep the secret OUT of any URL built here: a CACHE_URL with an embedded
# ${REDIS_PASSWORD} would interpolate before .secrets.env loads (→ blank
# password). Consume discrete REDIS_HOST/REDIS_PORT/REDIS_PASSWORD instead.
REDIS_HOST=redis
REDIS_PORT=6379
