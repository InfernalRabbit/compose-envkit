# ============================================
# Root DEV tier (cp example.dev.env .dev.env).
#
# Loaded after .env when CENVKIT_ENV=dev (the `.${ENV}.env` slot in
# .cenvkit.envchain). Per-environment, non-secret, last-wins over .env.
#
# IS_DEV is a CONVENTION, not engine magic: compose-envkit derives nothing — the
# value is literally this line. Keep the dev/prod pair in sync (true here,
# false in example.prod.env) so a single CENVKIT_ENV knob drives it.
# ============================================

IS_DEV=true

# Chain override example: SITE_URL is defined in example.env (base tier) and
# overridden here so `cenvkit env-debug --overview` shows the ~ marker for it.
SITE_URL=dev.example.com
