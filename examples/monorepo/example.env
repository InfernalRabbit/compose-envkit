# ============================================
# Root env (non-secret).  cp example.env .env  → fill in.
# Secrets go in .secrets.env (or per-subproject secret files). NEVER put
# passwords / keys / tokens here — this file is template-tracked (committed).
# ============================================

# Compose identity + which environment overlay to load.
COMPOSE_PROJECT_NAME=monorepo
CENVKIT_ENV=dev

# --- Compose file selection ------------------------------------------------
# The root docker-compose.yml include:s the subproject compose files; the
# trailing :docker-compose.${CENVKIT_ENV}.yml selects the per-env overlay
# (docker-compose.dev.yml / docker-compose.prod.yml). The plain ${CENVKIT_ENV}
# token resolves fine — CENVKIT_ENV is known when the chain is read (shell >
# .env) — so NO per-env re-pin is needed. (Only the ${VAR:+...} CONDITIONAL
# form, with the flag set in a LATER file, is the documented footgun.)
COMPOSE_FILE=docker-compose.yml:docker-compose.${CENVKIT_ENV}.yml

# --- Profiles (optional) ---------------------------------------------------
# A service with a `profiles:` key runs ONLY when its profile is selected;
# unprofiled services (web, api) always run. compose-envkit treats profiles as
# pure PASSTHROUGH — the ./docker shim forwards COMPOSE_PROFILES to compose
# unchanged, so set it in the shell or here. Catalog in this blueprint:
#   tools — optional helper container (OFF by default)
# Example:  COMPOSE_PROFILES=tools ./docker compose up
# COMPOSE_PROFILES=

# --- Root-level, cross-subproject (non-secret) -----------------------------
# Values the WHOLE stack shares belong here, in the root chain — these feed
# ${VAR} interpolation across all compose YAML. Per-subproject ports (WEB_PORT,
# API_PORT) deliberately do NOT live here: they sit in each subproject's own
# service env_file: (web/.web.env, api/.api.env) — runtime-only, container env.
# To promote one to interpolation, add it to this file (the Layer-1 chain).
SITE_URL=example.com
PUBLIC_URL=https://example.com
