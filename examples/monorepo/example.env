# ============================================
# Root env (non-secret).  cp example.env .env  → fill in.
# Secrets go in .secrets.env (or per-subproject secret files). NEVER put
# passwords / keys / tokens here — this file is template-tracked (committed).
# ============================================

# Compose identity + which environment overlay to load.
COMPOSE_PROJECT_NAME=monorepo
COMPOSE_ENV=dev

# --- Compose file selection ------------------------------------------------
# The root docker-compose.yml include:s the subproject compose files, so the
# base file alone gives the whole unified stack. Add per-env overlays with the
# usual ${COMPOSE_ENV} idiom if you split dev/prod (see the single-project
# example.* templates for the pattern).
COMPOSE_FILE=docker-compose.yml

# --- Root-level, cross-subproject (non-secret) -----------------------------
# Values the WHOLE stack shares belong here, in the root chain — natively
# interpolated, no Layer-2 needed. Per-subproject ports (WEB_PORT, API_PORT)
# deliberately do NOT live here: they sit in each subproject's own service
# env_file: (web/.web.env, api/.api.env) and are discovered via Layer-2, so a
# subproject stays self-contained and runnable standalone.
SITE_URL=example.com
PUBLIC_URL=https://example.com
