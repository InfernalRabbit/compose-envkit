# Service env_file: for the api subproject.
#
# Referenced by api/docker-compose.yml's `env_file:` — configures the api
# container at runtime (per-service, native Docker).
# It is NOT folded into COMPOSE_ENV_FILES, so ${API_PORT} in the YAML falls
# back to its :-0 default at interpolation time (the gap). Use
# `cenvkit env-debug --trace --var API_PORT` to inspect. To make API_PORT
# feed interpolation, add it to the Layer-1 chain (.env).
#
# In a real project this would be gitignored and seeded from an example.* —
# it carries no secrets here, so the blueprint ships it directly to stay
# runnable out of the box.
API_PORT=19090
