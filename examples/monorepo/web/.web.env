# Service env_file: for the web subproject.
#
# This file is referenced by web/docker-compose.yml's `env_file:` — it
# configures the web container at runtime (per-service, native Docker).
# It is NOT folded into COMPOSE_ENV_FILES, so ${WEB_PORT} in the YAML falls
# back to its :-0 default at interpolation time (the gap). Use
# `cenvkit env-debug --trace --var WEB_PORT` to inspect. To make WEB_PORT
# feed interpolation, add it to the Layer-1 chain (.env).
#
# In a real project this would be gitignored and seeded from an example.* —
# it carries no secrets here, so the blueprint ships it directly to stay
# runnable out of the box.
WEB_PORT=18080
