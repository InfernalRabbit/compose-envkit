# Service env_file: for the web subproject.
#
# This file is referenced by web/docker-compose.yml's `env_file:` — it both
# configures the container at runtime AND (via the kit's Layer-2 discovery)
# feeds compose-time ${WEB_PORT} interpolation. ONE place, two roles.
#
# In a real project this would be gitignored and seeded from an example.* —
# it carries no secrets here, so the blueprint ships it directly to stay
# runnable out of the box.
WEB_PORT=18080
