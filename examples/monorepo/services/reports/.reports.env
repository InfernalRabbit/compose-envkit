# Service env_file: for the reports subproject (nested under services/).
# REPORTS_PORT is defined ONLY here (runtime-only, container env). It is NOT
# folded into COMPOSE_ENV_FILES, so ${REPORTS_PORT} falls back to :-0 at
# compose-time interpolation. `cenvkit env-debug --trace --var REPORTS_PORT`
# surfaces the gap. Add it to the Layer-1 chain (.env) to make it interpolate.
REPORTS_PORT=15151
