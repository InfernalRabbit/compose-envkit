# ============================================
# .docker-env-chain — the ROOT project-level env chain (Layer 1).
#
# These are the files that drive ${VAR} interpolation in the root + included
# compose YAML. ${ENV} (a.k.a. ${COMPOSE_ENV}) resolves as shell COMPOSE_ENV >
# .env COMPOSE_ENV > "dev". Missing files are silently skipped. Last wins.
#
# Subproject service env_file: paths (web/.web.env, api/.api.env) are NOT listed
# here — they are runtime-only (per-service, native Docker container env). They
# do NOT feed ${VAR} interpolation. `cenvkit env-debug --files` shows both groups:
# Layer-1 interpolation files and runtime-only service env_file: paths by service.
# ============================================

# Layer 1: root base + env-specific overlay
.env
.${ENV}.env

# Per-machine override (optional): selected by the machine's hostname. Beats the
# shared .env / .${ENV}.env so a single dev box can tweak log levels, local
# paths, feature flags — but it is still ABOVE nothing secret: keep it BELOW
# .secrets.env. NEVER put secrets in a host file (it is not gitignored by the
# committed templates the way .secrets.env is). ${HOST} and ${HOSTNAME} are
# interchangeable; both resolve to the machine hostname. Missing file ⇒ skipped.
.${HOSTNAME}.env

# Secrets tier (last wins, gitignored). Last-wins within this Layer-1 chain.
# Per-subproject secrets belong in each subproject's own gitignored env file
# (e.g. web/.web.secrets.env) — listed there via service env_file: (runtime-only).
.secrets.env
