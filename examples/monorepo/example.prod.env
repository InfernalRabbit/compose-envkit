# ============================================
# Root PROD tier (cp example.prod.env .prod.env).
#
# Loaded after .env when CENVKIT_ENV=prod. The dev/prod overlay compose file is
# selected by COMPOSE_FILE's ${CENVKIT_ENV} token (see example.env), NOT by
# re-pinning here — a plain ${CENVKIT_ENV} resolves fine because CENVKIT_ENV is
# known when the chain is read (shell > .env). Only the ${VAR:+...} CONDITIONAL
# form (flag set in a later file) is the documented footgun.
# ============================================

IS_DEV=false
