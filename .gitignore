# compose-envkit — ignore real env files; keep the committed templates.
#
# The env-chain's runtime files are project-local and may carry secrets, so
# they must never be committed. The example.* / templates are tracked.

# Real env files (runtime copies of the templates)
.env
.*.env
.secrets.env

# But always keep the tracked templates
!example.env
!example.*.env
!example.secrets.env

# Editor / OS noise
.DS_Store
*.swp
*~

# Test scratch (smoke.sh uses mktemp, but guard local runs)
/tmp-smoke/

# Go build artifacts — never commit a built binary (spec: no committed binaries).
# NOTE: the vendored launcher `cenvkit` is a TRACKED POSIX shim, so do NOT ignore
# the bare name; the local fast-path build must be namespaced (e.g. .cenvkit.bin).
.cenvkit.bin
.cenvkit-bin
/dist/
